{
  "name": "@meetdave/agentmail",
  "version": "0.1.3",
  "description": "Local pull-only message bus for AI coding agents (Claude, Codex), with an Ink TUI dashboard and human-gated review.",
  "type": "module",
  "license": "MIT",
  "author": "Meet Dave <meet.dave@outlook.com> (https://github.com/meetdave3)",
  "homepage": "https://github.com/meetdave3/agentmail#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meetdave3/agentmail.git"
  },
  "bugs": {
    "url": "https://github.com/meetdave3/agentmail/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "codex",
    "agents",
    "ai-agents",
    "bus",
    "mail",
    "ink",
    "tui",
    "bun",
    "hono"
  ],
  "bin": {
    "agentmail": "bin/agentmail"
  },
  "files": [
    "bin",
    "src",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "bun run bin/agentmail",
    "typecheck": "bunx tsc --noEmit",
    "build:mcp": "bun build src/mcp/entry.ts --target=node --external undici --outfile=bin/mcp-entry.js",
    "postinstall": "bun run build:mcp",
    "test": "bun run build:mcp && bun tests/e2e.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "chalk": "^5.3.0",
    "hono": "^4.7.7",
    "ink": "^5.0.1",
    "marked": "^14.1.3",
    "marked-terminal": "^7.2.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/marked-terminal": "^6.1.1",
    "@types/react": "^18.3.12",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
